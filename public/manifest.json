{
  "manifest_version": 3,
  "name": "Reminder Hub",
  "version": "1.0.0",
  "description": "ניהול תזכורות חכם עם התראות בזמן אמת",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "notifications", "alarms"]
}
